# Release keystore configuration
# Copy this file to keystore.properties and fill in your actual values
# DO NOT commit keystore.properties to version control!
#
# Note: storeFile path is relative to android/app directory
# Example: if keystore is in android/app/, use: my-release-key.keystore
# Example: if keystore is in android/, use: ../my-release-key.keystore

storeFile=my-release-key.keystore
storePassword=your-store-password
keyAlias=my-key-alias
keyPassword=your-key-password

